#!/usr/bin/env bash

set -euo pipefail

cd "$(dirname "$0")"

command_name="${1:-help}"

require_docker() {
  if ! command -v docker >/dev/null 2>&1; then
    echo "Docker belum terpasang. Gunakan './bpad local' untuk menjalankan Laravel dengan SQLite sementara."
    exit 1
  fi
}

case "$command_name" in
  start)
    require_docker
    docker compose up -d --build
    echo "Website:  http://127.0.0.1:8000"
    echo "Database: http://127.0.0.1:8080"
    ;;
  stop)
    require_docker
    docker compose down
    ;;
  status)
    require_docker
    docker compose ps
    ;;
  logs)
    require_docker
    docker compose logs -f app
    ;;
  test)
    php artisan test
    ;;
  migrate)
    require_docker
    docker compose exec app php artisan migrate
    ;;
  admin)
    php artisan bpad:admin
    ;;
  backup)
    require_docker
    mkdir -p backups
    target="backups/bpadntt-$(date +%Y%m%d-%H%M%S).sql"
    docker compose exec -T postgres pg_dump -U bpadntt bpadntt > "$target"
    echo "Backup dibuat: $target"
    ;;
  local)
    php artisan migrate
    php artisan serve --host=127.0.0.1 --port=8000
    ;;
  *)
    echo "Perintah BPAD:"
    echo "  ./bpad local    Jalankan Laravel sekarang dengan SQLite"
    echo "  ./bpad start    Jalankan Laravel + PostgreSQL + Adminer"
    echo "  ./bpad stop     Hentikan container tanpa menghapus data"
    echo "  ./bpad status   Lihat status container"
    echo "  ./bpad logs     Lihat log aplikasi"
    echo "  ./bpad test     Jalankan pengujian"
    echo "  ./bpad migrate  Jalankan migration PostgreSQL"
    echo "  ./bpad admin    Buat atau perbarui akun admin"
    echo "  ./bpad backup   Backup PostgreSQL"
    ;;
esac
